# ─── Stripe (client) ─────────────────────────────────────────────
# Anything prefixed with VITE_ is exposed to the browser. Use ONLY
# the publishable key here — never put the secret key in this file.
VITE_STRIPE_PUBLISHABLE_KEY=pk_test_replace_me

# Optional override for the checkout API endpoint.
# Defaults to "/api/create-checkout-session" which works on Vercel.
# VITE_CHECKOUT_API=/api/create-checkout-session

# ─── Stripe (server) ─────────────────────────────────────────────
# Used only by the serverless function in api/. Keep this secret.
STRIPE_SECRET_KEY=sk_test_replace_me

# Public origin used to build success/cancel URLs (no trailing slash).
PUBLIC_SITE_URL=http://localhost:5173
